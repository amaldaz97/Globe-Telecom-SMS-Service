# M360 credentials (from Globe Business portal)
M360_APP_KEY=your-app-key
M360_APP_SECRET=your-app-secret
M360_SMS_URL=https://api.m360.com.ph/v3/api/broadcast

# REQUIRED: Globe-provisioned shortcode_mask linked to your app_key.
# Do NOT use placeholders like TEST or TEST_SENDER — M360 will reject them.
# Find this in: M360 portal → App/API settings → Sender ID / Masking name
M360_SENDER_ID=your-provisioned-shortcode-mask

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# HTTP client
REQUEST_TIMEOUT_MS=30000
